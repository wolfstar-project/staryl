{
	"name": "@wolfstar/staryl",
	"version": "1.0.0",
	"private": true,
	"description": "Your favourite Discord bot for notification, part of WolfStar Network",
	"license": "Apache-2.0",
	"author": "WolfStar Project <contact@wolfstar.rocks>",
	"type": "module",
	"main": "dist/main.mjs",
	"imports": {
		"#i18n": "./dist/lib/i18n/index.mjs",
		"#generated/prisma": "./dist/generated/prisma/client.mjs",
		"#types": "./dist/lib/types/index.mjs",
		"#types/*": "./dist/lib/types/*.mjs",
		"#lib/*": "./dist/lib/*.mjs",
		"#common/*": "./dist/lib/common/*.mjs",
		"#api/*": "./dist/api/*.mjs",
		"#utils/*": "./dist/lib/utilities/*.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "pnpm build --onSuccess \"pnpm start\"",
		"watch": "pnpm build --watch",
		"watch:start": "pnpm build --onSuccess \"pnpm start\"",
		"prisma:generate": "pnpm prisma generate",
		"clean": "node scripts/build/clean.mjs",
		"start": "node --enable-source-maps dist/main.mjs",
		"lint": "oxlint && oxfmt --check",
		"lint:fix": "oxlint --fix && oxfmt",
		"prepare": "node .husky/install.mjs || true",
		"update:interactive": "taze"
	},
	"dependencies": {
		"@discordjs/builders": "^1.14.1",
		"@discordjs/collection": "^2.1.1",
		"@discordjs/core": "^2.5.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sapphire/bitfield": "^1.2.4",
		"@sapphire/discord.js-utilities": "^7.3.3",
		"@sapphire/iterator-utilities": "^2.0.1",
		"@sapphire/ratelimits": "^2.4.11",
		"@sapphire/result": "^2.8.0",
		"@sapphire/time-utilities": "^1.7.14",
		"@sapphire/utilities": "^3.18.2",
		"@wolfstar/env-utilities": "^3.0.1",
		"@wolfstar/http-framework": "^3.0.1",
		"@wolfstar/http-framework-i18n": "^3.0.1",
		"@wolfstar/logger": "^3.0.1",
		"@wolfstar/safe-fetch": "^3.0.1",
		"@wolfstar/shared-http-pieces": "^3.0.1",
		"@wolfstar/start-banner": "^3.0.1",
		"@wolfstar/twitch-helpers": "^3.0.1",
		"discord-api-types": "^0.38.48",
		"fastify": "^5.8.5",
		"gradient-string": "^3.0.0",
		"husky": "^9.1.7",
		"ioredis": "^5.11.1",
		"nano-staged": "^1.0.2",
		"nanoid": "^5.1.11",
		"tsdown": "^0.22.2",
		"tslib": "^2.8.1",
		"untun": "^0.1.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@rollup/plugin-alias": "^6.0.0",
		"@sapphire/ts-config": "^5.0.3",
		"@types/node": "^24.13.2",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-regexp": "^3.1.0",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"prisma": "^7.8.0",
		"taze": "^19.14.1",
		"typescript": "~5.9.3"
	},
	"nano-staged": {
		"*.{js,ts,mjs,cjs}": [
			"pnpm oxlint --fix"
		],
		"*.{js,ts,mjs,cjs,json,yml,md}": [
			"pnpm oxfmt"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@11.6.0"
}
