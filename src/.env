CLIENT_VERSION=1.0.0

# Client ID which is used for the registry and various API calls
DISCORD_CLIENT_ID=

# Discord Client Public Key
DISCORD_PUBLIC_KEY=

REGISTRY_GUILD_ID=

# Sentry
SENTRY_DSN=

# The address and port on which to start the HTTP server
HTTP_ADDRESS=0.0.0.0
HTTP_PORT=3000

API_ADDRESS=0.0.0.0
API_PORT=3001

# Option required for the /twitch-subscription command
TWITCH_CALLBACK="http://localhost:3001/twitch/event_sub_verify/"
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_EVENT_SUB_SECRET=2

INTERNAL_RING_URL=
INTERNAL_RING_TOKEN=

# The database URL for Prisma, needs to be copied in a local `.env` at the root
# for Prisma's operations to work.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/starly?schema=public"
