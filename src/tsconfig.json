{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "..",
    "allowJs": true,
    "skipLibCheck": true,
    "resolvePackageJsonImports": true,
    "types": ["@types/node"]
  },
  "include": [".", "./**/*.json"],
  "exclude": ["./tsconfig.json", "../dist"]
}
