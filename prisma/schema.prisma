generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id BigInt  @id

  @@map("guild")
}



model GuildSubscription {
  guildId             BigInt              @map("guild_id")
  channelId           BigInt              @map("channel_id")
  message             String?             @db.VarChar(200)
  subscriptionId      BigInt                @map("subscription_id")
  twitchSubscription TwitchSubscription @relation(fields: [subscriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([guildId, channelId, subscriptionId])
  @@map("guild_subscription")
}



model TwitchSubscription {
  id                BigInt                   @id() @default(autoincrement())
  streamerId        String                 @map("streamer_id") @db.VarChar(10)
  subscriptionId    String                 @map("subscription_id") @db.VarChar(36)
  subscriptionType  TwitchSubscriptionType
  guildSubscription GuildSubscription[]

  @@unique([streamerId, subscriptionType])
  @@map("twitch_subscriptions")
}



enum TwitchSubscriptionType {
  StreamOnline  @map("stream.online")
  StreamOffline @map("stream.offline")

  @@map("twitch_subscriptions_subscription_type_enum")
}
